struct PSInput
{
    float4 ClipPos       : SV_POSITION;
    float4 Color         : COLOR;
};

float4 main(PSInput input) : SV_Target0
{
    float2 centered = float2(0.5f, 0.5f);
    float radiusSquared = dot(centered, centered);
    float alpha = smoothstep(1.08, 0.18, radiusSquared);
    float glow = smoothstep(0.36, 0.0, radiusSquared);
    float3 color = input.Color.rgb + (glow * 0.35f);
    return float4(color, input.Color.a * alpha);
}